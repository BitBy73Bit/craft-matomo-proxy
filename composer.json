{
    "name": "bitbytebit/craft-matomo-proxy",
    "description": "Proxy Matomo tracking requests through your own domain so the real Matomo server URL is never exposed to visitors or search engines.",
    "type": "craft-plugin",
    "license": "GPL-3.0-or-later",
    "keywords": [
        "craft",
        "cms",
        "craftcms",
        "craft-plugin",
        "matomo",
        "piwik",
        "analytics",
        "proxy"
    ],
    "authors": [
        {
            "name": "BitByteBit",
            "homepage": "https://bitbytebit.co.uk"
        }
    ],
    "support": {
        "issues": "https://github.com/BitBy73Bit/craft-matomo-proxy/issues",
        "source": "https://github.com/BitBy73Bit/craft-matomo-proxy"
    },
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.0.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "craftcms/ecs": "dev-main",
        "phpstan/phpstan": "^1.11",
        "craftcms/phpstan": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "bitbytebit\\matomoproxy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "bitbytebit\\matomoproxy\\tests\\": "tests/"
        }
    },
    "extra": {
        "handle": "matomo-proxy",
        "name": "Matomo Tracker Proxy",
        "developer": "BitByteBit",
        "developerUrl": "https://bitbytebit.co.uk",
        "documentationUrl": "https://github.com/BitBy73Bit/craft-matomo-proxy/blob/main/README.md",
        "changelogUrl": "https://raw.githubusercontent.com/BitBy73Bit/craft-matomo-proxy/main/CHANGELOG.md",
        "class": "bitbytebit\\matomoproxy\\Plugin"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true
        },
        "sort-packages": true
    },
    "scripts": {
        "check-cs": "ecs check",
        "fix-cs": "ecs check --fix",
        "phpstan": "phpstan --memory-limit=1G",
        "test": "phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
